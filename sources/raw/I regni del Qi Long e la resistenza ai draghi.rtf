\par \pard\plain \ltrpar\s1\cf0{\*\hyphen2\hyphlead2\hyphtrail2\hyphmax0}\aspalpha\ql\rtlch\af5\afs24\lang255\ltrch\dbch\af3\langfe255\hich\f0\fs24\lang1040\loch\f0\fs24\lang1040{\rtlch \ltrch\loch\f0\fs24\lang1040\i0\b0{\ltrch\dbch\hich\b\loch\b Razza:}}{\rtlch \ltrch\loch\f0\fs24\lang1040\i0\b0  Drago della Terra  {\ltrch\dbch\hich\b\loch\b Livello:} 80 {\rtlch\ltrch\dbch\hich\b\loch\b  Attitudine: }{Dormiente}{\rtlch\ltrch\dbch\hich\b\loch\b  Natura: }{Insondabile}}
