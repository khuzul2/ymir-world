\par \pard\plain \ltrpar\s2\cf0\qj{\*\hyphen2\hyphlead2\hyphtrail2\hyphmax0}\aspalpha\sa120\rtlch\af5\afs24\lang255\ab\ltrch\dbch\af3\langfe255\hich\f0\fs24\lang1040\b\loch\f0\fs24\lang1040\b {\rtlch \ltrch\loch\f0\fs24\lang1040\i0\b Cani Rossi: {\rtlch\ltrch\dbch\hich\b0\loch\b0 Un cane ha continuato ad abbaiare tutta notte, cos\'ec che \'e8 stato impossibile riposare. Che non si lamenti se alla mattina il padrone lo bastona.}}
\par \pard\plain \ltrpar\s2\cf0{\*\hyphen2\hyphlead2\hyphtrail2\hyphmax0}\aspalpha\sa120\ql\rtlch\af5\afs24\lang255\ltrch\dbch\af3\langfe255\hich\f0\fs24\lang1040\loch\f0\fs24\lang1040 {\rtlch \ltrch\loch\f0\fs24\lang1040\i0\b Falchi dorati: {\rtlch\ltrch\dbch\hich\b0\loch\b0 Una giusta parola al momento giusto pu\'f2 ferire pi\'f9 di un colpo di spada. Per fortuna  l'ebrezza del vino mi ha reso un po' sordo. }  }
\par \pard\plain \ltrpar\s2\cf0{\*\hyphen2\hyphlead2\hyphtrail2\hyphmax0}\aspalpha\sa120\ql\rtlch\af5\afs24\lang255\ltrch\dbch\af3\langfe255\hich\f0\fs24\lang1040\loch\f0\fs24\lang1040 {\rtlch \ltrch\loch\f0\fs24\lang1040\i0\b Scorpioni Neri: {\rtlch\ltrch\dbch\hich\b0\loch\b0 Chi mentre cammina guarda il cielo e non presta attenzione ai propri passi \'e8 uno sciocco. Chi lo fa in una caverna ancora di pi\'f9.}}
\par \pard\plain \ltrpar\s2\cf0{\*\hyphen2\hyphlead2\hyphtrail2\hyphmax0}\aspalpha\sa120\ql\rtlch\af5\afs24\lang255\ltrch\dbch\af3\langfe255\hich\f0\fs24\lang1040\loch\f0\fs24\lang1040 {\rtlch \ltrch\loch\f0\fs24\lang1040\i0\b Manguste Bianche: {\rtlch\ltrch\dbch\hich\b0\loch\b0  Ho visto un bonzo/ girare in tondo/ pregava e pregava/ ma nessuno lo ascoltava. }}
\par \pard\plain \ltrpar\s2\cf0{\*\hyphen2\hyphlead2\hyphtrail2\hyphmax0}\aspalpha\sa120\ql\rtlch\af5\afs24\lang255\ltrch\dbch\af3\langfe255\hich\f0\fs24\lang1040\loch\f0\fs24\lang1040 {\rtlch \ltrch\loch\f0\fs24\lang1040\i0\b Tigri Celesti: {\rtlch\ltrch\dbch\hich\b0\loch\b0 Sai cosa succede se lasci una spada immersa nell'acqua per troppo tempo? Si arrugginisce.}}
